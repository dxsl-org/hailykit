# Dependency directories
node_modules/

# Build outputs
dist/
out/
.test-build/
release/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Hook runtime logs (generated at runtime, never committed)
kit/hooks/.logs/
.claude/hooks/.logs/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# Project-specific references & agent files
.agents/
.reference/

# Project-local Claude Code runtime (auto-memory, session state)
.claude/

# Hook execution logs
.logs/

# Python bytecode caches (OCR engine + any bundled python tools)
__pycache__/
*.pyc
